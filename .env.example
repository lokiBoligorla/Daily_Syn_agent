# LLM Configuration
# Choose one of: gemini, openai, nvidia
LLM_PROVIDER=gemini

# Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# SMTP Configuration (For sending report emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_email_app_password_here

# Recipient Configuration
TEAM_LEAD_1=lead1@example.com
TEAM_LEAD_2=lead2@example.com
